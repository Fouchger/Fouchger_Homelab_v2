# ================================================================
# File: ansible/templates/traefik-dynamic.yml.j2
# Purpose:
#   Routing configuration for the Traefik dashboard endpoint.
# ================================================================
http:
  routers:
    traefik-dashboard:
      rule: Host(`traefik.{{ homelab_domain | default('fouchger.uk') }}`)
      entryPoints:
        - websecure
      service: api@internal
      tls:
        certResolver: cloudflare
        domains:
          - main: {{ homelab_domain | default('fouchger.uk') }}
            sans:
              - '*.{{ homelab_domain | default('fouchger.uk') }}'
